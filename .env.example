# Variables de entorno requeridas — copiar a .env.local y completar con valores reales.
# NUNCA subir .env.local a git (ya está en .gitignore).

# --- Envío de correos del formulario de contacto (SMTP Hostinger) ---
SMTP_USER=contacto@sacplanos.cl
SMTP_PASS=                       # Contraseña de la casilla SMTP (NO subir el valor real)
EMAIL_TO=administracion@sacplanos.cl

# --- URL pública del sitio ---
NEXT_PUBLIC_SITE_URL=https://sacplanos.cl
